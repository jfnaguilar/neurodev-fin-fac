# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/neurodev_fin?schema=public"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-here-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# Redis (for BullMQ)
REDIS_URL="redis://localhost:6379"

# S3-Compatible Storage
S3_ENDPOINT="https://s3.amazonaws.com"
S3_REGION="us-east-1"
S3_BUCKET="neurodev-fin"
S3_ACCESS_KEY="your-access-key"
S3_SECRET_KEY="your-secret-key"

# OCR (optional)
GOOGLE_VISION_API_KEY=""
AWS_TEXTRACT_REGION=""

# Encryption
ENCRYPTION_KEY="32-char-hex-key-for-aes256-encryption"
