  CANCELLED
  ERROR
}

// ─── OPEN FINANCE (PLUGGY) ────────────────────────────────────────────────────

model PluggyConnection {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  itemId      String    @unique @map("item_id")
  connectorId Int       @map("connector_id")
  bankName    String    @map("bank_name")
  status      String    @default("UPDATED")
  error       String?
  lastSync    DateTime? @map("last_sync")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  accounts PluggyAccount[]

  @@map("pluggy_connections")
}

model PluggyAccount {
  id           String    @id @default(cuid())
  connectionId String    @map("connection_id")
  tenantId     String    @map("tenant_id")
  pluggyId     String    @unique @map("pluggy_id")
  name         String
  number       String?
  bankData     Json      @default("{}") @map("bank_data")
  type         String
  subtype      String?
  currencyCode String    @default("BRL") @map("currency_code")
  balance      Decimal   @db.Decimal(15, 2)
  syncedAt     DateTime? @map("synced_at")

  connection   PluggyConnection  @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  transactions PluggyTransaction[]

  @@map("pluggy_accounts")
}

model PluggyTransaction {
  id          String   @id @default(cuid())
  accountId   String   @map("account_id")
  tenantId    String   @map("tenant_id")
  pluggyId    String   @unique @map("pluggy_id")
  date        DateTime
  description String
  amount      Decimal  @db.Decimal(15, 2)
  type        String
  category    String?
  bankData    Json?    @map("bank_data")
  reconciled  Boolean  @default(false)
  titleId     String?  @map("title_id")
  titleType   String?  @map("title_type")
  createdAt   DateTime @default(now()) @map("created_at")

  account PluggyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("pluggy_transactions")
}

// ─── FIADORES E GARANTIAS REAIS ──────────────────────────────────────────────

model Guarantor {
  id            String        @id @default(cuid())
  tenantId      String        @map("tenant_id")
  contractId    String?       @map("contract_id")
  name          String
  document      String?
  documentType  String?       @default("CPF") @map("document_type")
  email         String?
  phone         String?
  address       Json?
  type          GuarantorType @default(GUARANTOR)
  notes         String?
  isActive      Boolean       @default(true) @map("is_active")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  contract Contract? @relation(fields: [contractId], references: [id])

  @@map("guarantors")
}

enum GuarantorType {
  GUARANTOR   // fiador clássico
  CO_DEBTOR   // codevedores solidário
}

model RealGuarantee {
  id                 String        @id @default(cuid())
  tenantId           String        @map("tenant_id")
  contractId         String?       @map("contract_id")
  type               GuaranteeType
  description        String
  estimatedValue     Decimal?      @db.Decimal(15, 2) @map("estimated_value")
  registrationNumber String?       @map("registration_number")
  details            Json          @default("{}")
  isActive           Boolean       @default(true) @map("is_active")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  contract Contract? @relation(fields: [contractId], references: [id])

  @@map("real_guarantees")
}

enum GuaranteeType {
  PROPERTY       // imóvel
  VEHICLE        // veículo
  BANK_GUARANTEE // carta fiança bancária
  INSURANCE      // seguro fiança
  FINANCIAL      // aplicações financeiras / CDB
  OTHER
}

// ─── GENNERA SYNC LOG ─────────────────────────────────────────────────────────

model SyncLog {
  id             String    @id @default(cuid())
  tenantId       String    @map("tenant_id")
  provider       String    @default("GENNERA")
  syncType       String    @map("sync_type")
  status         String    @default("RUNNING")
  recordsTotal   Int       @default(0) @map("records_total")
  recordsCreated Int       @default(0) @map("records_created")
  recordsUpdated Int       @default(0) @map("records_updated")
  recordsError   Int       @default(0) @map("records_error")
  errorMessage   String?   @map("error_message")
  details        Json      @default("[]")
  startedAt      DateTime  @default(now()) @map("started_at")
  finishedAt     DateTime? @map("finished_at")

  @@index([tenantId])
  @@index([syncType, startedAt(sort: Desc)])
  @@map("sync_logs")
}
