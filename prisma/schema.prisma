  CANCELLED
  EXPIRED
}

enum BoletoStatus {
  PENDING
  PAID
  CANCELLED
  EXPIRED
}

model InvoiceEmission {
  id                String        @id @default(cuid())
  tenantId          String        @map("tenant_id")
  receivableTitleId String?       @map("receivable_title_id")
  paymentTitleId    String?       @map("payment_title_id")
  provider          String
  externalId        String?       @map("external_id")
  ref               String?
  protocol          String?
  accessKey         String?       @map("access_key")
  series            String?
  number            String?
  pdfUrl            String?       @map("pdf_url")
  xmlUrl            String?       @map("xml_url")
  status            InvoiceStatus @default(PENDING)
  errorMessage      String?       @map("error_message")
  issuedAt          DateTime?     @map("issued_at")
  canceledAt        DateTime?     @map("canceled_at")
  emailSentAt       DateTime?     @map("email_sent_at")
  emailSentTo       String?       @map("email_sent_to")
  createdAt         DateTime      @default(now()) @map("created_at")
